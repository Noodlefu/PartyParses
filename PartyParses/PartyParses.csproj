<?xml version="1.0" encoding="utf-8"?>
<Project Sdk="Dalamud.NET.Sdk/15.0.0">
  <PropertyGroup>
    <Authors>Noodlefu</Authors>
    <Version>0.0.0.1</Version>
    <Description>Shows your current party/raid/alliance's best FFLogs parse for the duty you're in.</Description>
    <PackageProjectUrl>https://github.com/Noodlefu/PartyParses</PackageProjectUrl>
    <PackageLicenseExpression>AGPL-3.0-or-later</PackageLicenseExpression>
    <IsPackable>false</IsPackable>
  </PropertyGroup>

  <ItemGroup>
    <None Update="PartyParses.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>
</Project>
